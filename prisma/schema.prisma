generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Category {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  products  Product[]
  createdAt DateTime  @default(now())
}

model Product {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  description String?
  details     String?
  materials   String?
  care        String?
  price       Float
  salePrice   Float?
  status      String        @default("ACTIVE") // ACTIVE | SOLD_OUT | PRE_ORDER | DRAFT
  isLimited   Boolean       @default(false)
  images      String        @default("[]") // JSON array of URLs
  category    Category      @relation(fields: [categoryId], references: [id])
  categoryId  String
  variants    Variant[]
  preorders   Preorder[]
  coupons     ProductCoupon[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}


model Variant {
  id        String  @id @default(cuid())
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
  size      String
  stock     Int     @default(0)
  sku       String?
}

model Coupon {
  id              String          @id @default(cuid())
  code            String          @unique
  discountPercent Float
  active          Boolean         @default(true)
  usageLimit      Int?
  usageCount      Int             @default(0)
  expiresAt       DateTime?
  products        ProductCoupon[]
  createdAt       DateTime        @default(now())
}

model ProductCoupon {
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
  coupon    Coupon  @relation(fields: [couponId], references: [id], onDelete: Cascade)
  couponId  String
  @@id([productId, couponId])
}

model Lead {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  message   String?
  source    String   @default("home")
  createdAt DateTime @default(now())
}

model Preorder {
  id        String   @id @default(cuid())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
  name      String
  email     String
  phone     String?
  note      String?
  createdAt DateTime @default(now())
}

model Newsletter {
  id        String   @id @default(cuid())
  email     String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Order {
  id              String      @id @default(cuid())
  name            String
  email           String
  phone           String?
  address         String?
  note            String?
  total           Float
  status          String      @default("PENDING_PAYMENT") // PENDING_PAYMENT | PAID | CONFIRMED | SHIPPED | DELIVERED | CANCELLED
  stripeSessionId String?
  items           OrderItem[]
  createdAt       DateTime    @default(now())
}

model OrderItem {
  id          String @id @default(cuid())
  order       Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId     String
  productName String
  size        String
  price       Float
  qty         Int
}
